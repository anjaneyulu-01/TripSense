# ============================================================
# TripSense Backend — Environment Variables
# Copy this file to `.env` and fill in the real values.
# NEVER commit the real .env file.
# ============================================================

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database (MongoDB Atlas) ---
MONGODB_URI=your_mongodb_atlas_connection_string_here
MONGODB_DB_NAME=tripsense

# --- Auth / JWT ---
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI Providers ---
# Fallback chain (in order): Grok (xAI) -> Groq (groq.com) -> Gemini (Google).
# Only providers with a key are used; configure any subset. NOTE: "Grok" (xAI)
# and "Groq" (groq.com) are DIFFERENT services with different keys.

# Grok (xAI) — key from https://console.x.ai (starts with "xai-").
GROK_API_KEY=your_xai_grok_api_key_here
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-3

# Groq (groq.com) — key from https://console.groq.com (starts with "gsk_").
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (Google) — key from https://aistudio.google.com/apikey.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

# Per-request timeout (seconds) before failing over to the next provider.
AI_REQUEST_TIMEOUT=30
