# ============================================================
# TripSense — root .gitignore (covers frontend + backend)
# ============================================================

# --- Secrets / environment (NEVER commit) ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Node / frontend ---
node_modules/
dist/
dist-ssr/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Python / backend ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Logs ---
logs/
*.log

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors / IDEs ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# --- Build / misc ---
*.tsbuildinfo
.cache/
tmp/
temp/
